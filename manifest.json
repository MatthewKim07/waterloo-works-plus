{
  "manifest_version": 3,
  "name": "WaterlooWorks+",
  "description": "Client-side WaterlooWorks intelligence: resume matching, job parsing, and ratings insights.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://waterlooworks.uwaterloo.ca/*",
    "*://*.waterlooworks.uwaterloo.ca/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "icons": {
    "16": "src/assets/icons/icon-16.png",
    "32": "src/assets/icons/icon-32.png",
    "48": "src/assets/icons/icon-48.png",
    "128": "src/assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "WaterlooWorks+",
    "default_icon": {
      "16": "src/assets/icons/icon-16.png",
      "32": "src/assets/icons/icon-32.png",
      "48": "src/assets/icons/icon-48.png"
    },
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/app/app.html",
  "content_scripts": [
    {
      "matches": [
        "*://waterlooworks.uwaterloo.ca/*",
        "*://*.waterlooworks.uwaterloo.ca/*"
      ],
      "all_frames": true,
      "js": [
        "src/shared/schema.js",
        "src/shared/storage.js",
        "src/shared/skills.js",
        "src/shared/utils.js",
        "src/shared/resume-parser.js",
        "src/shared/job-parser.js",
        "src/shared/ratings-parser.js",
        "src/shared/scoring.js",
        "src/shared/ui.js",
        "src/shared/ww-selectors.js",
        "src/shared/ww-dom-adapter.js",
        "src/shared/job-identity.js",
        "src/shared/profile-store.js",
        "src/shared/application-store.js",
        "src/content/common.js",
        "src/content/listings.js",
        "src/content/posting.js",
        "src/content/ratings.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/assets/icons/icon-16.png",
        "src/assets/icons/icon-32.png",
        "src/assets/icons/icon-48.png",
        "src/assets/icons/icon-128.png",
        "src/assets/icons/logo.png"
      ],
      "matches": [
        "*://waterlooworks.uwaterloo.ca/*",
        "*://*.waterlooworks.uwaterloo.ca/*"
      ]
    }
  ]
}
